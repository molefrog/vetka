DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# App
VITE_APP_URL=https://vetka.sh
# Root domain for generated sites (e.g. "evan.web.sh"). Defaults to web.sh.
VITE_SUBDOMAIN_ROOT=web.sh

# better-auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://vetka.sh

# Login: email OTP + Google
# Email delivery for OTP codes (Resend). If unset, codes are logged to the
# server console (fine for local development).
# RESEND_API_KEY=
# EMAIL_FROM=Vetka <login@vetka.sh>

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Anthropic Managed Agent (used to build generated sites)
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides — defaults are baked into src/lib/agent.server.ts
# ANTHROPIC_AGENT_ID=
# ANTHROPIC_ENV_ID=

# Object storage for deployed static sites.
# Driver: "local" (filesystem, default in dev) or "s3" (any S3-compatible bucket).
# STORAGE_DRIVER=local
# STORAGE_LOCAL_DIR=./.storage
#
# Cloudflare R2 (S3-compatible). Setting R2_ENDPOINT + R2_BUCKET selects the s3 driver.
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=vetka-sites
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
#
# AWS S3 alternative:
# S3_ENDPOINT=
# S3_BUCKET=
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
